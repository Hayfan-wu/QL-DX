# 中国电信话费自动化 - 环境变量
# 由 QQ 机器人自动生成

# 电信手机号
DX_PHONE=

# 登录密码
DX_PASSWORD=

# 启用签到 (true/false)
DX_ENABLE_SIGNIN=true

# 启用兑换 (true/false)
DX_ENABLE_EXCHANGE=true

# 启用活动扫描 (true/false)
DX_ENABLE_ACTIVITY=true

# 启用秒杀 (true/false)
DX_ENABLE_FLASH_SALE=true

# 兑换阈值金豆数
DX_MIN_BEANS_TO_EXCHANGE=100

# 秒杀时间 (HH:MM:SS)
DX_FLASH_SALE_TIME=10:00:00

# 无头模式 (true/false)
DX_HEADLESS=true

# 超时秒数
DX_TIMEOUT=30