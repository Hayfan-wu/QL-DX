# ============================================
# 中国电信话费自动化 - 环境变量配置
# 复制此文件为 .env 并修改，或发送 电信登录 通过QQ配置
# ============================================

# ---------- 电信账号（格式: 手机号#密码）----------
DX_ACCOUNT=

# ---------- 青龙面板 ----------
QL_URL=http://127.0.0.1:5700
QL_CLIENT_ID=
QL_CLIENT_SECRET=

# ---------- 功能开关 ----------
DX_ENABLE_SIGNIN=true
DX_ENABLE_ACTIVITY=true
DX_ENABLE_FLASH_SALE=true

# ---------- 秒杀时间 ----------
DX_FLASH_SALE_TIME=10:00:00

# ---------- 浏览器 ----------
DX_HEADLESS=true
DX_TIMEOUT=30