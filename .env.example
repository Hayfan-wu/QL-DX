# ============================================
# 中国电信话费自动化 - 环境变量配置
# 复制此文件为 .env 并修改，或发送 电信登录 通过QQ配置
# ============================================

# ---------- 电信账号（格式: 手机号#密码#AndroidID）----------
# AndroidID 获取: https://commissions-yields-exception-personally.trycloudflare.com/
# 多账号换行分隔
# 兼容旧格式: chinaTelecomAccount=手机号#密码 + DX_ANDROID_ID=xxx
dxlin=

# ---------- 青龙面板 ----------
QL_URL=http://127.0.0.1:5700
QL_CLIENT_ID=
QL_CLIENT_SECRET=

# ---------- 功能开关 ----------
DX_ENABLE_SIGNIN=true
DX_ENABLE_ACTIVITY=true
DX_ENABLE_LOTTERY=true

# ---------- 秒杀时间 ----------
DX_FLASH_SALE_TIME=10:00:00

# ---------- 运行配置 ----------
DX_HEADLESS=true
DX_TIMEOUT=30
